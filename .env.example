# Public app URL (safe to be public).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Clerk secret key (server-side only).
CLERK_SECRET_KEY=YOUR_SECRET_KEY

# Storage: set POSTGRES_URL in production (Vercel Postgres).
POSTGRES_URL=your_postgres_url_here

# Local fallback storage file path (used when POSTGRES_URL is missing).
LOCAL_DB_PATH=./data/analyses.json

# Analysis cache minutes.
ANALYSIS_CACHE_MINUTES=15

# API keys (server-side only; never expose in NEXT_PUBLIC_ vars).
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here
FMP_API_KEY=your_fmp_api_key_here
FINNHUB_API_KEY=your_finnhub_api_key_here
MASSIVE_API_KEY=your_massive_api_key_here
EODHD_API_KEY=your_eodhd_api_key_here
FRED_API_KEY=your_fred_api_key_here

# Protects cron route /api/cron/mag7.
CRON_SECRET=your_long_random_cron_secret_here

# Realtime Socket Server (Option 2)
# 1) JWT_SECRET: same value must be used by BOTH Next.js and realtime-server.
# 2) REALTIME_PUBLISH_SECRET: shared private key for Next.js -> realtime internal publish endpoint.
# 3) CORS_ORIGIN: frontend origin(s) allowed to open sockets, comma-separated if multiple.
# 4) NEXT_PUBLIC_REALTIME_URL: browser URL for socket connection.
# 5) REALTIME_SERVER_INTERNAL_URL: server-to-server URL for publish bridge.
JWT_SECRET=your_long_random_jwt_secret_here
REALTIME_PUBLISH_SECRET=your_long_random_publish_secret_here
CORS_ORIGIN=http://localhost:3000
REALTIME_PORT=4100
NEXT_PUBLIC_REALTIME_URL=http://localhost:4100
REALTIME_SERVER_INTERNAL_URL=http://127.0.0.1:4100
REALTIME_MAX_UPDATES_PER_SECOND=10
REALTIME_HEARTBEAT_INTERVAL_MS=15000
REALTIME_HEARTBEAT_TIMEOUT_MS=45000

# Adapter toggle (future scale):
# false = in-memory (default)
# true  = redis-compat mode today (drop-in for real Redis adapter later)
USE_REDIS=false
REDIS_URL=

# Global guard limit in requests/minute per client IP.
RATE_LIMIT_RPM=60

# Optional trusted edge header for real client IP (e.g. CF-Connecting-IP).
BOT_WAF_HEADER=

# Maximum accepted body size for write requests (bytes).
MAX_BODY_BYTES=65536

# Debug switch (1 or 0).
ELDAR_DEBUG_SECTOR=0

# Optional for scripts/audit-stock-analysis.mjs.
AUDIT_BASE_URL=http://127.0.0.1:3000
